# Headers para Cloudflare Pages / Netlify

# ───────── Seguridad (todas las rutas) ─────────
# Cabeceras de alto valor y cero riesgo para un sitio estático.
# NOTA: NO se define Content-Security-Policy a propósito. El sitio usa handlers
# inline (oninput en el formulario, onload en el CSS diferido) y cargará el
# Google tag de Ads; un CSP útil exigiría 'unsafe-inline' (lo vacía de sentido)
# y arriesga romper el tag. Si en el futuro se refactorizan los inline y se
# conoce el dominio del tag, agregar aquí un CSP afinado.
/*
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin
  X-Frame-Options: SAMEORIGIN
  Strict-Transport-Security: max-age=31536000; includeSubDomains
  Permissions-Policy: camera=(), microphone=(), geolocation=(), payment=()
  Cross-Origin-Opener-Policy: same-origin

# ───────── Cache ─────────
# Assets estables (img, css, js, video, fuentes): cache fuerte e inmutable
/assets/*
  Cache-Control: public, max-age=31536000, immutable

# Favicons e iconos en la raíz: cache largo
/favicon.ico
  Cache-Control: public, max-age=2592000
/favicon-16x16.png
  Cache-Control: public, max-age=2592000
/favicon-32x32.png
  Cache-Control: public, max-age=2592000
/apple-touch-icon.png
  Cache-Control: public, max-age=2592000
/android-chrome-192x192.png
  Cache-Control: public, max-age=2592000
/android-chrome-512x512.png
  Cache-Control: public, max-age=2592000
/og-image.jpg
  Cache-Control: public, max-age=2592000

# HTML y manifest: siempre revalidar
/
  Cache-Control: public, max-age=0, must-revalidate
/index.html
  Cache-Control: public, max-age=0, must-revalidate
/site.webmanifest
  Cache-Control: public, max-age=0, must-revalidate
