# Cache-Control para Cloudflare Pages / Netlify

# Assets estables (img, css, js, video): cache fuerte e inmutable
/assets/*
  Cache-Control: public, max-age=31536000, immutable
  X-Content-Type-Options: nosniff

# Favicons e iconos en la raíz: cache largo
/favicon.ico
  Cache-Control: public, max-age=2592000
/favicon-16x16.png
  Cache-Control: public, max-age=2592000
/favicon-32x32.png
  Cache-Control: public, max-age=2592000
/apple-touch-icon.png
  Cache-Control: public, max-age=2592000
/android-chrome-192x192.png
  Cache-Control: public, max-age=2592000
/android-chrome-512x512.png
  Cache-Control: public, max-age=2592000
/og-image.jpg
  Cache-Control: public, max-age=2592000

# HTML y manifest: siempre revalidar
/
  Cache-Control: public, max-age=0, must-revalidate
  X-Content-Type-Options: nosniff
/index.html
  Cache-Control: public, max-age=0, must-revalidate
/site.webmanifest
  Cache-Control: public, max-age=0, must-revalidate
